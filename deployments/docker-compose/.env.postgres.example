# Postgres deployment environment. Mirrors the default (MySQL) compose
# file but swaps the database driver/DSN to Postgres and removes
# MySQL-specific variables.
#
# Copy to .env and edit the values marked REQUIRED.

# Database — Postgres 16.
POSTGRES_USER=micro_one_api
POSTGRES_PASSWORD=change-me
POSTGRES_DB=micro_one_api
DATABASE_DRIVER=postgres
DATABASE_DSN=host=postgres user=micro_one_api password=change-me dbname=micro_one_api port=5432 sslmode=disable

# Redis
REDIS_PASSWORD=change-me

# Service authentication — REQUIRED.
JWT_SECRET_KEY=change-me-to-a-long-random-string
SERVICE_TOKEN=change-me-to-a-long-random-string
ADMIN_TOKEN=change-me-to-a-long-random-string

# Initial admin bootstrap
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=

# Payment defaults
RECHARGE_AMOUNT_MULTIPLIER=10
PAYMENT_QUOTA_PER_UNIT=500000
ALIPAY_ENABLED=false
ALIPAY_FORM_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_CERT_DIR=../../cert/alipay
ALIPAY_PRIVATE_KEY=
ALIPAY_PRIVATE_KEY_PATH=/cert/alipay/application_private_key.pem
ALIPAY_PUBLIC_KEY=
ALIPAY_PUBLIC_KEY_PATH=/cert/alipay/alipay_public_key.pem
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_APP_CERT_PATH=
ALIPAY_ROOT_CERT_PATH=
ALIPAY_PUBLIC_CERT_PATH=

# Channel health circuit breaker
CHANNEL_HEALTH_FAILURE_THRESHOLD=3
CHANNEL_HEALTH_COOLDOWN=5m
CHANNEL_HEALTH_CHECK_ENABLED=true
CHANNEL_HEALTH_CHECK_INTERVAL=5m
CHANNEL_HEALTH_CHECK_TIMEOUT=10s

# Channel health alerts
CHANNEL_HEALTH_ALERT_ENABLED=true
CHANNEL_HEALTH_ALERT_NOTIFY_TYPE=webhook
CHANNEL_HEALTH_ALERT_RECIPIENTS=[""]

# Reconciliation alerts
NOTIFY_GRPC_ENDPOINT=notify-worker:9008
RECON_ALERT_ENABLED=true
RECON_ALERT_NOTIFY_TYPE=email
RECON_ALERT_RECIPIENTS=["ops@example.com"]
RECON_ALERT_INTERVAL=1h
NOTIFY_WEBHOOK_URL=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=
NOTIFY_SMTP_FROM=
NOTIFY_DISPATCH_INTERVAL=30s
NOTIFY_DISPATCH_BATCH=20
NOTIFY_MAX_RETRY=3
