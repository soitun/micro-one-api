# Database Configuration (REQUIRED)
DATABASE_DSN=user:password@tcp(host:3306)/oneapi

# Redis Configuration
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Service Addresses
IDENTITY_GRPC_ADDR=127.0.0.1:9001
IDENTITY_HTTP_ADDR=0.0.0.0:8001
CHANNEL_GRPC_ADDR=127.0.0.1:9002
CHANNEL_HTTP_ADDR=0.0.0.0:8002
BILLING_GRPC_ADDR=127.0.0.1:9003
BILLING_HTTP_ADDR=0.0.0.0:8003
RELAY_HTTP_ADDR=:8080

# Client Endpoints
IDENTITY_GRPC_ENDPOINT=127.0.0.1:9001
CHANNEL_GRPC_ENDPOINT=127.0.0.1:9002
BILLING_GRPC_ENDPOINT=127.0.0.1:9003

# Provider Configuration
RELAY_PROVIDER_TIMEOUT=30s
RELAY_MAX_TIMEOUT=5m

# Security Configuration
# TLS Configuration
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_CA_FILE=

# mTLS Configuration
MTLS_ENABLED=false
MTLS_CLIENT_CERT_FILE=
MTLS_CLIENT_KEY_FILE=

# Service Authentication (REQUIRED)
JWT_SECRET_KEY=
SERVICE_TOKEN=
ADMIN_TOKEN=

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# IP Filtering
IP_WHITELIST=
IP_BLACKLIST=

# Registration Controls
REGISTRATION_DISABLED=false
REGISTRATION_EMAIL_DOMAIN_RESTRICTION_ENABLED=false
REGISTRATION_EMAIL_DOMAIN_WHITELIST=[]
TURNSTILE_CHECK_ENABLED=false
TURNSTILE_SECRET=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Environment
ENV=development
