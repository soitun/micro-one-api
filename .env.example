# Database Configuration (REQUIRED)
MYSQL_ROOT_PASSWORD=
DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/oneapi?charset=utf8mb4&parseTime=True&loc=Local

# Redis Configuration
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Service Addresses
IDENTITY_GRPC_ADDR=127.0.0.1:9001
IDENTITY_HTTP_ADDR=0.0.0.0:8001
CHANNEL_GRPC_ADDR=127.0.0.1:9002
CHANNEL_HTTP_ADDR=0.0.0.0:8002
BILLING_GRPC_ADDR=127.0.0.1:9004
BILLING_HTTP_ADDR=0.0.0.0:8004
RELAY_HTTP_ADDR=:8080

# Client Endpoints
IDENTITY_GRPC_ENDPOINT=127.0.0.1:9001
CHANNEL_GRPC_ENDPOINT=127.0.0.1:9002
BILLING_GRPC_ENDPOINT=127.0.0.1:9004
# admin-api uses this HTTP endpoint for log detail and cleanup proxy actions.
LOG_HTTP_ENDPOINT=http://127.0.0.1:8006

# Channel Health Circuit Breaker
CHANNEL_HEALTH_FAILURE_THRESHOLD=3
CHANNEL_HEALTH_COOLDOWN=5m
CHANNEL_HEALTH_CHECK_ENABLED=true
CHANNEL_HEALTH_CHECK_INTERVAL=5m
CHANNEL_HEALTH_CHECK_TIMEOUT=10s
CHANNEL_HEALTH_ALERT_ENABLED=true
CHANNEL_HEALTH_ALERT_NOTIFY_TYPE=webhook
CHANNEL_HEALTH_ALERT_RECIPIENTS=[""]

# Provider Configuration
RELAY_PROVIDER_TIMEOUT=30s
RELAY_MAX_TIMEOUT=5m
OAUTH_OIDC_ENABLED=false
OAUTH_OIDC_CLIENT_ID=
OAUTH_OIDC_CLIENT_SECRET=
OAUTH_OIDC_AUTHORIZE_URL=
OAUTH_OIDC_TOKEN_URL=
OAUTH_OIDC_USER_INFO_URL=
OAUTH_OIDC_SCOPES=[openid,email,profile]

# Security Configuration
# TLS Configuration
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_CA_FILE=

# mTLS Configuration
MTLS_ENABLED=false
MTLS_CLIENT_CERT_FILE=
MTLS_CLIENT_KEY_FILE=

# Service Authentication (REQUIRED)
JWT_SECRET_KEY=
SERVICE_TOKEN=
ADMIN_TOKEN=

# Initial Admin Bootstrap (identity-service, first-start only)
# When the users table is empty on startup, identity-service creates a root
# admin from these values. If INITIAL_ADMIN_PASSWORD is empty, a random
# 16-char hex password is generated and printed once at WARN level — change
# it via login immediately. Existing users skip bootstrap entirely.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# IP Filtering
IP_WHITELIST=
IP_BLACKLIST=

# Registration Controls
REGISTRATION_DISABLED=false
REGISTRATION_EMAIL_DOMAIN_RESTRICTION_ENABLED=false
REGISTRATION_EMAIL_DOMAIN_WHITELIST=[]
TURNSTILE_CHECK_ENABLED=false
TURNSTILE_SECRET=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Environment
ENV=development

# Alipay sandbox
ALIPAY_ENABLED=true
ALIPAY_FORM_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=YOUR_ALIPAY_APP_ID
ALIPAY_PRIVATE_KEY_PATH=/cert/alipay/application_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/cert/alipay/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-public-domain.example.com/api/v1/user/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-frontend-domain.example.com/payment/result

# Notifications (channel-service / billing-service → notify-worker)
# When reconciliation finds discrepancies (account quota drift, channel
# usage mismatch, ledger/log double-write skew), billing-service dials the
# NOTIFY_GRPC_ENDPOINT and creates a notification per recipient via
# notify-worker. Leave NOTIFY_GRPC_ENDPOINT empty to disable alerts
# (legacy log-only mode).
#
# Recipients is a JSON array; entries are notification targets passed to
# notify-worker. For webhook/event alerts, leave them empty to use
# NOTIFY_WEBHOOK_URL or set target URLs directly; for email alerts, use mail
# addresses. Example for production: RECON_ALERT_RECIPIENTS=["ops@example.com"]
NOTIFY_GRPC_ENDPOINT=notify-worker:9008
RECON_ALERT_ENABLED=true
RECON_ALERT_NOTIFY_TYPE=email
RECON_ALERT_RECIPIENTS=["ops@example.com"]
RECON_ALERT_INTERVAL=1h

# notify-worker delivery settings. Webhook/event notifications use the
# recipient URL when it is a URL, otherwise NOTIFY_WEBHOOK_URL as fallback.
NOTIFY_WEBHOOK_URL=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=
NOTIFY_SMTP_FROM=

# Enterprise WeCom (WeCom) notifications
# Provide full webhook URL (https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx)
# or just the key (will be used to build the full URL)
NOTIFY_WECOM_WEBHOOK_URL=

# DingTalk notifications
# Provide full webhook URL (https://oapi.dingtalk.com/robot/send?access_token=xxx)
# or just the access_token (will be used to build the full URL)
NOTIFY_DINGTALK_WEBHOOK_URL=

# Feishu (Lark) notifications
# Provide the full webhook URL
NOTIFY_FEISHU_WEBHOOK_URL=

# Slack notifications
# Provide the incoming webhook URL
NOTIFY_SLACK_WEBHOOK_URL=

NOTIFY_DISPATCH_INTERVAL=30s
NOTIFY_DISPATCH_BATCH=20
NOTIFY_MAX_RETRY=3
